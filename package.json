{
  "name": "emergency-balancer",
  "version": "1.0.0",
  "description": "A high-performance, fault-tolerant load balancer for emergency and critical infrastructure scenarios",
  "main": "src/core/balancer.js",
  "bin": {
    "eb": "./scripts/cli.js"
  },
  "scripts": {
    "start": "node src/core/server.js",
    "dev": "nodemon src/core/server.js",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "docker:build": "docker build -t emergency-balancer .",
    "docker:run": "docker-compose up"
  },
  "keywords": [
    "load-balancer",
    "proxy",
    "circuit-breaker",
    "health-check",
    "failover",
    "emergency",
    "infrastructure",
    "high-availability"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "http-proxy": "^1.18.1",
    "express": "^4.18.2",
    "yaml": "^2.3.4",
    "commander": "^11.1.0",
    "prom-client": "^15.1.0",
    "winston": "^3.11.0",
    "node-cron": "^3.0.3",
    "uuid": "^9.0.0",
    "chalk": "^4.1.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "nodemon": "^3.0.2",
    "eslint": "^8.56.0",
    "nock": "^13.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js"
    ]
  }
}
